{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting"
  ],
  "dependencyDashboard": true,
  "flux": {
    "managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "description": "CloudNativePG Cluster imageName",
      "customType": "regex",
      "managerFilePatterns": ["/flux/.+\\.ya?ml$/"],
      "matchStrings": [
        "imageName:\\s+(?<depName>[^:\\s]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Kustomization github ?ref= URLs",
      "customType": "regex",
      "managerFilePatterns": ["/flux/.+/kustomization\\.ya?ml$/"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/]+)(?:/[^?\\s]*)?\\?ref=(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "description": "Grafana dashboards (grafana.com revision)",
      "customType": "regex",
      "managerFilePatterns": ["/flux/.+\\.ya?ml$/"],
      "matchStrings": [
        "#\\s+renovate:\\s+depName=\"(?<depName>.*)\"\\s*\\n\\s+id:\\s+(?<packageName>\\d+)\\s*\\n\\s+revision:\\s+(?<currentValue>\\d+)"
      ],
      "versioningTemplate": "regex:^(?<major>\\d+)$",
      "datasourceTemplate": "custom.grafana-dashboards"
    }
  ],
  "customDatasources": {
    "grafana-dashboards": {
      "defaultRegistryUrlTemplate": "https://grafana.com/api/dashboards/{{packageName}}",
      "format": "json",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $string(revision)}]}"
      ]
    }
  },
  "packageRules": [
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "ignoreTests": true
    }
  ]
}
