{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableRateLimiting"
  ],
  "dependencyDashboard": true,
  "flux": {
    "managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "description": "CloudNativePG Cluster imageName",
      "customType": "regex",
      "managerFilePatterns": ["/flux/.+\\.ya?ml$/"],
      "matchStrings": [
        "imageName:\\s+(?<depName>[^:\\s]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "description": "Kustomization github ?ref= URLs",
      "customType": "regex",
      "managerFilePatterns": ["/flux/.+/kustomization\\.ya?ml$/"],
      "matchStrings": [
        "https://github\\.com/(?<depName>[^/]+/[^/]+)(?:/[^?\\s]*)?\\?ref=(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "ignoreTests": true
    }
  ]
}
