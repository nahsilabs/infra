{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "hostRules": [
    {
      "matchHost": "dock.mau.dev",
      "hostType": "docker"
    }
  ],
  "flux": {
    "managerFilePatterns": [
      "/flux/*/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/flux/*/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/flux/*/.+\\.ya?ml$/"
    ]
  }
}
