{
  "uid": "myspeed",
  "title": "MySpeed",
  "editable": true,
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Download",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_download) * 1e6", "instant": true, "legendFormat": "Download" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 300000000 }, { "color": "green", "value": 580000000 } ] } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Upload",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_upload) * 1e6", "instant": true, "legendFormat": "Upload" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 300000000 }, { "color": "green", "value": 580000000 } ] } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ping",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_ping)", "instant": true, "legendFormat": "Ping" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 4 }, { "color": "red", "value": 8 } ] } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Jitter",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_jitter)", "instant": true, "legendFormat": "Jitter" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "justifyMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 } ] } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg duration",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(avg_over_time(myspeed_time[$__range]))", "instant": true, "legendFormat": "Duration" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "textMode": "auto", "justifyMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Server",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "myspeed_server_info", "instant": true, "legendFormat": "{{server_name}}" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "none", "textMode": "name", "justifyMode": "auto", "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Speed",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_download) * 1e6", "legendFormat": "Download" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_upload) * 1e6", "legendFormat": "Upload" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "none" } },
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "pointSize": 5, "spanNulls": true, "axisPlacement": "auto" } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Ping & Jitter",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_ping)", "legendFormat": "Ping" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_ping) + (max(myspeed_jitter) or vector(0))", "legendFormat": "Jitter high" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(myspeed_ping) - (max(myspeed_jitter) or vector(0))", "legendFormat": "Jitter low" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["min", "max", "mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "none" } },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "fillOpacity": 0, "showPoints": "auto", "pointSize": 5, "spanNulls": true, "axisPlacement": "auto" }, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ping" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "Jitter high" }, "properties": [ { "id": "custom.fillBelowTo", "value": "Jitter low" }, { "id": "custom.lineWidth", "value": 0 }, { "id": "custom.fillOpacity", "value": 25 }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }, { "id": "custom.hideFrom", "value": { "legend": true, "tooltip": true, "viz": false } } ] },
          { "matcher": { "id": "byName", "options": "Jitter low" }, "properties": [ { "id": "custom.lineWidth", "value": 0 }, { "id": "custom.hideFrom", "value": { "legend": true, "tooltip": true, "viz": false } } ] }
        ]
      }
    },
    {
      "id": 8,
      "type": "state-timeline",
      "title": "Availability",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(up{job=\"myspeed\"})", "legendFormat": "Status" }
      ],
      "options": { "mergeValues": true, "showValue": "never", "alignValue": "center", "rowHeight": 0.9, "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80, "lineWidth": 0 }, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }, "mappings": [ { "type": "value", "options": { "0": { "text": "Down", "color": "red", "index": 0 }, "1": { "text": "Up", "color": "green", "index": 1 } } } ], "noValue": "No data" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Download values",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "min(min_over_time(myspeed_download[$__range])) * 1e6", "instant": true, "legendFormat": "Minimum" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(max_over_time(myspeed_download[$__range])) * 1e6", "instant": true, "legendFormat": "Maximum" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(avg_over_time(myspeed_download[$__range])) * 1e6", "instant": true, "legendFormat": "Average" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "justifyMode": "auto", "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Upload values",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "min(min_over_time(myspeed_upload[$__range])) * 1e6", "instant": true, "legendFormat": "Minimum" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(max_over_time(myspeed_upload[$__range])) * 1e6", "instant": true, "legendFormat": "Maximum" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(avg_over_time(myspeed_upload[$__range])) * 1e6", "instant": true, "legendFormat": "Average" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "justifyMode": "auto", "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "bps", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
    }
  ]
}
